<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    tools:context=".KategoriEdit">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/aksen">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"

                    app:iconGravity="textStart"
                    app:icon="@drawable/back"
                    app:iconTint="@android:color/white"

                    app:backgroundTint="#1E4D96"
                    app:cornerRadius="14dp"

                    app:iconPadding="0dp"

                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"

                    android:text="Edit Kategori"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD FORM -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"

                app:strokeColor="#D6E4FF"
                app:strokeWidth="1dp"

                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- LABEL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Nama Kategori"
                        android:textStyle="bold"
                        android:textColor="#2C5EAD"
                        android:textSize="15sp"

                        android:layout_marginBottom="8dp"/>

                    <!-- INPUT -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="@android:color/white"

                        app:boxStrokeColor="#2C5EAD"

                        app:boxCornerRadiusTopStart="18dp"
                        app:boxCornerRadiusTopEnd="18dp"
                        app:boxCornerRadiusBottomStart="18dp"
                        app:boxCornerRadiusBottomEnd="18dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputKategori"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"

                            android:hint="Masukkan nama kategori"

                            android:textColor="#111111"
                            android:textColorHint="#999999"

                            android:paddingVertical="12dp"
                            android:includeFontPadding="false"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSimpanEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        android:layout_marginTop="10dp"

                        android:text="Simpan"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"

                        android:textColor="@android:color/white"

                        app:backgroundTint="#2C5EAD"
                        app:cornerRadius="18dp"

                        android:paddingVertical="14dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHapusKategori"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        android:layout_marginTop="0dp"

                        android:text="Hapus Kategori"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="15sp"

                        android:textColor="@android:color/white"

                        app:backgroundTint="@color/black"
                        app:cornerRadius="18dp"

                        android:paddingVertical="14dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>